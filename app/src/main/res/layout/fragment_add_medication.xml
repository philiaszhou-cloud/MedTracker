<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 娣诲姞鑽墿鏍囬 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="娣诲姞鑽墿"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="16dp" />

        <!-- 鑽墿鍚嶇О -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMedName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="鑽墿鍚嶇О锛堝锛氶樋鍙稿尮鏋楋級"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMedName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 棰滆壊閫夋嫨 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="鑽墿棰滆壊"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <View
                android:id="@+id/viewSelectedColor"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/color_indicator_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvSelectedColor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="鐧借壊"
                android:textSize="14sp"
                android:textColor="#616161" />
        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupColors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            android:layout_marginBottom="16dp" />

        <!-- 褰㈢姸閫夋嫨 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="鑽墿褰㈢姸"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupShapes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            android:layout_marginBottom="16dp" />

        <!-- 鍓傞噺 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="姣忔鍓傞噺"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/etDosage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 澶囨敞 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="澶囨敞锛堝彲閫夛紝濡傦細楗悗鏈嶇敤锛?
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:maxLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 鍙傝€冪収鐗?-->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="鍙傝€冪収鐗囷紙鍙€夛級"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMedPhoto"
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="12dp"
            app:strokeColor="#BDBDBD"
            app:strokeWidth="1dp"
            android:layout_marginBottom="24dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/imgMedPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="鑽墿鍙傝€冪収鐗? />

                <TextView
                    android:id="@+id/tvPhotoHint"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="馃摲\n鐐瑰嚮閫夋嫨鐓х墖"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 鎸夐挳鍖哄煙 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="鍙栨秷"
                app:cornerRadius="8dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="淇濆瓨鑽墿"
                app:backgroundTint="#4CAF50"
                app:cornerRadius="8dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
